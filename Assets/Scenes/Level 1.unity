  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0412 \u0438\u0433\u0440\u0435 <b>God of the Garden</b> \u0432\u0430\u043C
    \u043F\u0440\u0435\u0434\u0441\u0442\u043E\u0438\u0442 \u0441\u043F\u0430\u0441\u0442\u0438
    \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u044F \u043E\u0442 \u0437\u043E\u043C\u0431\u0438\n\n*
    \u041F\u043E\u043B\u0438\u0432\u0430\u0439\u0442\u0435 \u0438\u0445 \u0434\u043E\u0436\u0434\u0435\u043C,
    \u0447\u0442\u043E\u0431\u044B \u043E\u043D\u0438 \u043D\u0435 \u0437\u0430\u0441\u043E\u0445\u043B\u0438\n*
    \u0423\u0431\u0438\u0432\u0430\u0439\u0442\u0435 \u0437\u043E\u043C\u0431\u0438
    \u043C\u043E\u043B\u043D\u0438\u044F\u043C\u0438 \n* \u0417\u0430\u043C\u0435\u0434\u043B\u044F\u0439\u0442\u0435
    \u0437\u043E\u043C\u0431\u0438 \u0441\u043D\u0435\u0433\u043E\u043C\n\n\u0412\u0441\u043F\u044B\u0448\u043A\u0430
    \u043C\u043E\u043B\u043D\u0438\u0438 \u043F\u043E <b>\u043C\u043E\u043A\u0440\u043E\u043C\u0443</b>
    \u0446\u0432\u0435\u0442\u043A\u0443 \u043B\u0435\u0447\u0438\u0442 \u0435\u0433\u043E.\n\u0412\u0441\u043F\u044B\u0448\u043A\u0430
    \u043C\u043E\u043B\u043D\u0438\u0438 \u043F\u043E <b>\u043C\u043E\u043A\u0440\u043E\u043C\u0443</b>
    \u0437\u043E\u043C\u0431\u0438 \u0443\u0431\u0438\u0432\u0430\u0435\u0442 \u0435\u0433\u043E.\n\n<b>\u0423\u0434\u0430\u0447\u0438</b>"
